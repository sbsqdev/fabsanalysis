{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/analyze.ts":          { "maxDuration": 60 },
    "api/transform.ts":        { "maxDuration": 60 },
    "api/lip-visualize.ts":    { "maxDuration": 60 },
    "api/apipay/create.ts":    { "maxDuration": 15 },
    "api/apipay/status.ts":    { "maxDuration": 15 },
    "api/apipay/webhook.ts":   { "maxDuration": 15 },
    "api/admin/index.ts":      { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy",   "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy",  "value": "require-corp" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/ingest/static/(.*)", "destination": "https://us-assets.i.posthog.com/static/$1" },
    { "source": "/ingest/(.*)",        "destination": "https://us.i.posthog.com/$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
