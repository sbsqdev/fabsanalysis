# ====================================
# BEAUTY PLATFORM — Environment Variables
# Copy to .env.local for development
# ====================================

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side Supabase (service role — never expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Get your publishable key from Stripe Dashboard
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- OpenAI (for face analysis AI recommendations) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- FAL.ai (for face transformation visualizations) ---
FAL_KEY=...
FAL_MODEL=fal-ai/flux-kontext-lora/inpaint

# --- Server ---
PORT=4173
